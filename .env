# ─── Queue ────────────────────────────────────────────────────────────
QUEUE_NAME=ProductSearchQueue
QUEUE_JOB_NAME=search-product
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_DELAY_MS=2000
JOB_RETENTION_COMPLETED=500
JOB_RETENTION_FAILED=1000
JOB_TIMEOUT_MS=600000
QUEUE_RATE_LIMIT_MAX=20
QUEUE_RATE_LIMIT_DURATION_MS=60000
QUEUE_STALLED_INTERVAL_MS=30000
QUEUE_MAX_STALLED_COUNT=1
# ─── Worker ───────────────────────────────────────────────────────────
WORKER_CONCURRENCY=4
WORKER_HEARTBEAT_MS=15000
WORKER_OFFLINE_TIMEOUT_MS=90000
WORKER_SWEEP_INTERVAL_MS=30000
# ─── Scraper ──────────────────────────────────────────────────────────
MAX_PRODUCTS=500
MAX_RETRIES=3
RETRY_DELAY_MS=1500
AFFILIATE_CID=286505
SUPABASE_BATCH_SIZE=25
SEARCH_RESULTS_PER_TERM=8
REQUEST_DELAY_MS=1200
AXIOS_TIMEOUT_MS=25000
ENABLE_TERM_FILTERING=true
# ─── Misc ─────────────────────────────────────────────────────────────
CORS_ORIGIN=*
LOG_LEVEL=info
